# ─────────────────────────────────────────────────────────────────────────────
# Growth Feed — environment configuration
# Copy this file to `.env.local` and fill in the values. Restart `npm run dev`
# after editing.
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase web config (client) ────────────────────────────────────────────
# Firebase Console → Project settings → General → Your apps → SDK setup & config.
#
# Required setup in the Firebase console:
#   1. Realtime Database: Build → Realtime Database → Create database. Then paste
#      the per-user rules from `database.rules.json` (Realtime Database → Rules).
#   2. Google sign-in: Build → Authentication → Sign-in method → enable Google.
#      (localhost is an authorized domain by default; add your prod domain later.)
#
# All NEXT_PUBLIC_* vars are exposed to the browser (that's expected for the
# Firebase web config) and are also read server-side by the crawler.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# The owner's Google account email — the ONLY account allowed to sign in and use
# the app. Must match the literal email in your deployed database.rules.json.
NEXT_PUBLIC_OWNER_EMAIL=

# ── Crawler (server-side, Firebase Admin SDK) ────────────────────────────────
# The crawler writes feed items with the Admin SDK (bypasses security rules).
# Firebase Console → Project settings → Service accounts → Generate new private
# key. Then base64-encode the JSON and paste it here:
#   macOS:  base64 -i serviceAccountKey.json | pbcopy
FIREBASE_SERVICE_ACCOUNT_B64=

# Optional: skips an Admin Auth lookup. If unset, the crawler auto-detects the
# single owner under /users. Find it in Authentication → Users (User UID).
OWNER_UID=

# Optional but recommended: enables richer interest-matched YouTube results via
# the YouTube Data API v3 (https://console.cloud.google.com → enable "YouTube
# Data API v3" → Credentials → API key). Without it, only channel RSS is used.
YOUTUBE_API_KEY=

# Shared secret protecting the POST /api/cron/crawl endpoint (used by Vercel Cron
# or a manual curl). Generate any random string, e.g. `openssl rand -hex 24`.
CRON_SECRET=
